# ═══════════════════════════════════════════════════════
# LERNEN — Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Models
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Lernen

# ─── E2E Test Users ─────────────────────────────────────────────────────────────
# These are created by: npx tsx scripts/seed-test-data.ts
TEST_SUPER_ADMIN_EMAIL=admin@lernen.edu
TEST_SUPER_ADMIN_PASSWORD=testpassword123
TEST_PRINCIPAL_EMAIL=principal@oakridge.edu
TEST_PRINCIPAL_PASSWORD=testpassword123
TEST_TEACHER_EMAIL=teacher@oakridge.edu
TEST_TEACHER_PASSWORD=testpassword123
TEST_STUDENT_EMAIL=student@oakridge.edu
TEST_STUDENT_PASSWORD=testpassword123
